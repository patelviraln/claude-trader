ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
TRADIER_API_TOKEN=your_tradier_api_token_here
POLYGON_API_KEY=your_polygon_api_key_here
# --- AI thesis generation (OpenRouter) ---
# Required — get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional — primary model. Swap to any model on OpenRouter without code changes.
SCANNER_MODEL=openai/gpt-oss-120b:free

# Optional — used automatically if the primary model errors. Set to "" to disable.
SCANNER_FALLBACK_MODEL=google/gemini-2.5-flash

# --- Daily summary notifications (optional) ---
# Subscribe to this topic in the ntfy app (https://ntfy.sh) to get the daily
# run summary as a push notification. Unset = summary goes to logs/daily_summary.md
NTFY_TOPIC=
